        "jsonBody": "={\n  \"subscriber_id\": {{ $('Webhook').item.json.body.record.ig_id }},\n  \"data\": {\n    \"version\": \"v2\",\n    \"content\": {\n      \"type\": \"instagram\",\n      \"messages\": [\n        {\n          \"type\": \"text\",\n          \"text\": {{ JSON.stringify($json.output) }}\n        }\n      ]\n    }\n  }\n}",
