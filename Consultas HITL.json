    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  let text = item.json.output || \"\";\n  \n  // Definimos ambos triggers (Venta y Reunión)\n  const triggerVenta = \"perfecto, entre los proximos 2 dias habiles se contactara un diseñador con vos\";\n  const triggerReunion = \"genial, te esperamos en la reunion\";\n  const tag = \"[STATUS: CLOSED]\";\n\n  // 1. Detección de cierre (evalúa si tiene la frase de venta, la de reunión, o directamente el tag)\n  item.json.should_close = text.toLowerCase().includes(triggerVenta.toLowerCase()) || \n                           text.toLowerCase().includes(triggerReunion.toLowerCase()) ||\n                           text.includes(tag);\n\n  // 2. Limpieza INTELIGENTE\n  let cleanOutput = text\n    .replace(tag, \"\") // Borramos el tag técnico\n    .replace(/\\n{3,}/g, '\\n\\n') // Si hay 3 o más saltos de línea seguidos, deja solo 2.\n    .trim(); // Quita espacios vacíos al inicio y final\n\n  item.json.output = cleanOutput;\n  \n  return item;\n});"
      },
